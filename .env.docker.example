# Copy to .env.docker and fill in. Used by docker-compose (the API container
# also derives DATABASE_URL from POSTGRES_PASSWORD — don't set it here).

# --- Database (compose-managed Postgres) ---
POSTGRES_PASSWORD=change-me-strong-password

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Server ---
PORT=5003
NODE_ENV=production
# The deployed frontend origin (Vercel) — CORS + socket.io are locked to it.
FRONTEND_URL=https://your-app.vercel.app

# --- First boot only ---
# Seed one user per role (<role>@email.com / SEED_PASSWORD) on container start.
# Set to 1 for the FIRST start, then remove/0 it.
SEED_USERS=0
SEED_PASSWORD=change-me

# --- File storage (Cloudflare R2; all four set => R2, else local volume) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=operator-crm-docs
