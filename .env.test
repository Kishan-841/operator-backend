# Test environment — points at an ISOLATED database. Tests truncate freely, so
# this MUST be a *_test database (helpers.mjs refuses to run otherwise).
# Loaded via `node --env-file=.env.test` (see the "test" npm script).
DATABASE_URL="postgresql://gazon@localhost:5432/operator_crm_test?schema=public"
JWT_SECRET="test-secret"
JWT_EXPIRES_IN="1h"
NODE_ENV="test"
