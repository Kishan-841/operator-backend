# --- Database ---
# Separate Postgres database from ISP_CRM (CLAUDE.md §4).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/operator_crm?schema=public"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- Server ---
# This repo runs on 5003 (5002 is taken by the sister "customer tracker" project).
# Keep this in sync with frontend NEXT_PUBLIC_API_URL.
PORT=5003
FRONTEND_URL="http://localhost:3001"
NODE_ENV="development"

# --- Seed ---
# All seeded users are <role>@email.com (e.g. sales@email.com) with this password.
SEED_PASSWORD="123456"

# --- File storage (Cloudflare R2) ---
# All four set => documents upload to the R2 bucket (kept PRIVATE; downloads
# stream through the API). Any missing => falls back to local backend/uploads.
# Account ID: R2 overview page. Keys: R2 -> Manage R2 API Tokens ->
# "Object Read & Write" token scoped to this bucket.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="operator-crm-docs"